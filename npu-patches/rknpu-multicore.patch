+/*
+ * Mainline rockchip-iommu binds a DMA master to exactly ONE iommu node
+ * (its of_xlate is last-wins).  On RK3588 the three NPU cores sit behind
+ * separate MMU banks; a core whose bank is NOT managed by the bound iommu
+ * node runs with its MMU in bypass and emits raw physical addresses as
+ * IOVAs — silent memory corruption, not just a fault.  Only allow cores
+ * 1/2 when the bound iommu node's "reg" actually covers their MMU banks
+ * (0xfdaca000 / 0xfdada000), i.e. the multi-core 4-bank DT overlay is
+ * active.  Under the single-IOMMU overlay this clamps to core 0, keeping
+ * the driver consistent with whichever overlay booted.
+ */
+#define RK3588_NPU_CORE1_MMU_BASE 0xfdaca000UL
+#define RK3588_NPU_CORE2_MMU_BASE 0xfdada000UL
+
+/* NPU core power domains pre-attached + pre-powered in rknpu_init(); borrowed
+ * by rknpu_probe(). See rknpu_preinit_power_domains(). */
+static struct device *rknpu_pinned_genpd[3];	/* [0]=npu0 [1]=npu1 [2]=npu2 */
+/* core1/core2 MMU bus clocks (ACLK/HCLK_NPU1/2) held ON alongside the
+ * domains: rk_iommu only ungates its own NPU0 aclk/iface, so without these
+ * the iommu's access to the core1/core2 MMU banks would hit gated bus
+ * clocks (bus hang / abort). */
+static struct clk *rknpu_pinned_clk[4];		/* aclk1 aclk2 hclk1 hclk2 */
+static bool rknpu_preinit_done;
+
+/*
+ * True iff the NPU's BOUND iommu node (of_xlate is last-wins, so the LAST
+ * "iommus" entry) has reg banks covering BOTH the core1 (0xfdaca000) and
+ * core2 (0xfdada000) MMU banks — i.e. the multi-core 4-bank overlay is
+ * active and it is safe to run cores 1/2 (their MMUs are attached, not
+ * bypassed).
+ */
+static bool rknpu_iommu_covers_cores12(struct device *dev)
+{
+	struct of_phandle_args args;
+	struct resource res;
+	bool has_core1 = false, has_core2 = false;
+	int count, i;
+
+	if (!of_device_is_compatible(dev->of_node, "rockchip,rk3588-rknpu"))
+		return false;
+
+	count = of_count_phandle_with_args(dev->of_node, "iommus",
+					   "#iommu-cells");
+	if (count <= 0)
+		return false;
+
+	if (of_parse_phandle_with_args(dev->of_node, "iommus", "#iommu-cells",
+				       count - 1, &args))
+		return false;
+
+	for (i = 0; of_address_to_resource(args.np, i, &res) == 0; i++) {
+		if (res.start == RK3588_NPU_CORE1_MMU_BASE)
+			has_core1 = true;
+		else if (res.start == RK3588_NPU_CORE2_MMU_BASE)
+			has_core2 = true;
+	}
+	of_node_put(args.np);
+
+	return has_core1 && has_core2;
+}
+
+static u32 rknpu_effective_core_mask(struct device *dev,
+				     const struct rknpu_config *config)
+{
+	if (config->core_mask <= RKNPU_CORE0_MASK)
+		return config->core_mask;
+
+	if (rknpu_iommu_covers_cores12(dev))
+		return config->core_mask;
+
+	LOG_DEV_INFO(
+		dev,
+		"bound IOMMU does not cover NPU core1/core2 MMU banks, limiting to core 0\n");
+	return RKNPU_CORE0_MASK;
+}
+
