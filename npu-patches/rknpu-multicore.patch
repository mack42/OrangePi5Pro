+/*
+ * Multi-core NPU power-domain pre-attach (see the long comment in
+ * rknpu_probe). The single mainline rk_iommu that manages all NPU MMU banks
+ * is a PM-runtime device-link supplier of the NPU platform device, so the
+ * driver core resumes it (rk_iommu_enable → programs every bank) inside
+ * really_probe()'s pm_runtime_get_suppliers(), BEFORE rknpu_probe() runs.
+ * core1/core2 MMU banks are in PD_NPU1/PD_NPU2; touching them while off is a
+ * synchronous external abort. The only module-level hook that runs before
+ * that resume is module init, here — so pre-attach and power the three NPU
+ * core power domains before platform_driver_register(). rknpu_probe() then
+ * borrows these handles instead of re-attaching. Only done when the bound
+ * IOMMU actually spans core1/core2 banks (the 4-bank multi-core overlay);
+ * under the single-IOMMU overlay this is a no-op.
+ */
+static void rknpu_preinit_power_domains(void)
+{
+	static const char *const names[3] = { "npu0", "npu1", "npu2" };
+	struct device_node *np;
+	struct platform_device *pdev;
+	struct device *dev, *vd;
+	int i;
+
+	np = of_find_compatible_node(NULL, NULL, "rockchip,rk3588-rknpu");
+	if (!np)
+		return;
+	pdev = of_find_device_by_node(np);
+	of_node_put(np);
+	if (!pdev)
+		return;
+	dev = &pdev->dev;
+
+	if (of_count_phandle_with_args(dev->of_node, "power-domains",
+				       "#power-domain-cells") < 3 ||
+	    !rknpu_iommu_covers_cores12(dev)) {
+		/* single-core / non-multi-core DT: nothing to pre-power */
+		platform_device_put(pdev);
+		return;
+	}
+
+	for (i = 0; i < 3; i++) {
+		int ret;
+
+		vd = dev_pm_domain_attach_by_name(dev, names[i]);
+		if (IS_ERR_OR_NULL(vd)) {
+			pr_info("rknpu: preinit attach %s -> %ld\n", names[i],
+				PTR_ERR(vd));
+			rknpu_pinned_genpd[i] = NULL;
+			continue;
+		}
+		rknpu_pinned_genpd[i] = vd;
+		ret = pm_runtime_get_sync(vd);
+		pr_info("rknpu: preinit power-on %s: get_sync=%d\n", names[i],
+			ret);
+	}
+
+	{
+		static const char *const clk_names[4] = { "aclk1", "aclk2",
+							  "hclk1", "hclk2" };
+		struct clk *c;
+
+		for (i = 0; i < 4; i++) {
+			c = clk_get(dev, clk_names[i]);
+			if (IS_ERR(c)) {
+				pr_info("rknpu: preinit clk_get %s -> %ld\n",
+					clk_names[i], PTR_ERR(c));
+				rknpu_pinned_clk[i] = NULL;
+				continue;
+			}
+			clk_prepare_enable(c);
+			rknpu_pinned_clk[i] = c;
+		}
+	}
+	rknpu_preinit_done = true;
+	pr_info("rknpu: pre-powered NPU core power domains before driver bind (npu0=%s npu1=%s npu2=%s)\n",
+		rknpu_pinned_genpd[0] ? "ok" : "null",
+		rknpu_pinned_genpd[1] ? "ok" : "null",
+		rknpu_pinned_genpd[2] ? "ok" : "null");
+
+	/* keep the device ref while pinned; released in rknpu_exit */
+}
+
+static void rknpu_preexit_power_domains(void)
+{
+	int i;
+
+	if (!rknpu_preinit_done)
+		return;
+	for (i = 3; i >= 0; i--) {
+		if (rknpu_pinned_clk[i]) {
+			clk_disable_unprepare(rknpu_pinned_clk[i]);
+			clk_put(rknpu_pinned_clk[i]);
+			rknpu_pinned_clk[i] = NULL;
+		}
+	}
+	for (i = 2; i >= 0; i--) {
+		if (rknpu_pinned_genpd[i]) {
+			pm_runtime_put_sync(rknpu_pinned_genpd[i]);
+			dev_pm_domain_detach(rknpu_pinned_genpd[i], true);
+			rknpu_pinned_genpd[i] = NULL;
+		}
+	}
+	rknpu_preinit_done = false;
+}
+
 static int rknpu_init(void)
 {
+	rknpu_preinit_power_domains();
 	return platform_driver_register(&rknpu_driver);
 }
 
 static void rknpu_exit(void)
 {
 	platform_driver_unregister(&rknpu_driver);
+	rknpu_preexit_power_domains();
 }
 
 late_initcall(rknpu_init);
