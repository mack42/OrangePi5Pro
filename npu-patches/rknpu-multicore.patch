+				rknpu_dev->genpd_dev_npu2 ? "ok" : "null");
+		} else {
+			virt_dev = dev_pm_domain_attach_by_name(dev, "npu0");
 			if (!IS_ERR(virt_dev))
-				rknpu_dev->genpd_dev_npu2 = virt_dev;
+				rknpu_dev->genpd_dev_npu0 = virt_dev;
+			virt_dev = dev_pm_domain_attach_by_name(dev, "npu1");
